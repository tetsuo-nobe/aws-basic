{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowS3BucketOperationsWithPrefix",
      "Effect": "Allow",
      "Action": [
        "s3:CreateBucket",
        "s3:DeleteBucket",
        "s3:PutEncryptionConfiguration"
      ],
      "Resource": "arn:aws:s3:::tnobe0615-*"
    },
    {
      "Sid": "AllowS3ObjectOperationsWithPrefix",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::tnobe0615-*/*"
    }
  ]
}